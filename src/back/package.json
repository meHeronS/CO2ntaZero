{
  "name": "co2ntazero-backend",
  "version": "1.0.0",
  "description": "Backend da aplicação CO2ntaZero - Sistema de Gestão de Pegada de Carbono.",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "concurrently \"npm:start:backend\" \"npm:start:react\" \"npm:summary\"",
    "start:legacy": "concurrently \"npm:start:backend\" \"npm:start:legacy-ui\"",
    "start:backend": "node server.js",
    "start:react": "wait-on http://localhost:5000/api/health && npm start --prefix ../front/react",
    "start:legacy-ui": "wait-on http://localhost:5000/api/health && http-server ../front/legacy -p 8080 -c-1 --cors",
    "dev": "nodemon server.js",
    "summary": "wait-on tcp:5000 && node Scripts/print-summary.js",
    "create-test-users": "node -r dotenv/config ./scripts/create-test-companies.js"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.0",
    "mongoose": "^8.19.3",
    "morgan": "^1.10.1",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.1.0",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "http-server": "^14.1.1",
    "nodemon": "^3.1.10",
    "wait-on": "^7.2.0"
  }
}
