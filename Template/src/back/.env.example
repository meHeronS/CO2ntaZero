# ==============================================================================
# VARIÁVEIS DE AMBIENTE - CO2ntaZero (MOLDE ACADÊMICO)
# ==============================================================================
# Renomeie este arquivo para .env na sua máquina local antes de rodar.

# Porta que o servidor vai rodar localmente (No Azure, ele ignora e usa a própria)
PORT=5000

# Conexão do MongoDB Atlas (Cole o link do cluster de estudos acadêmico aqui)
MONGO_URI=mongodb+srv://<usuario>:<senha>@cluster-estudos.mongodb.net/co2ntazero?retryWrites=true&w=majority

# Segredo para gerar os Tokens de Login (Pode ser qualquer string no ambiente local)
JWT_SECRET=academic_secret_co2ntazero_2026

# URL do Frontend (Para configurar o CORS - Ex: http://localhost:3000 ou link da Vercel)
FRONTEND_URL=http://localhost:3000